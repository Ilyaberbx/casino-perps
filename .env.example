# Privy dashboard: enable the 'email' login method for this app (passkey is no
# longer a login method). Embedded EVM wallets are auto-provisioned for users
# without wallets, becoming their Primary Wallet at onboarding. To support the
# optional 2FA step, also enable Multi-factor authentication (authenticator app /
# TOTP) in the Privy dashboard.
VITE_PRIVY_APP_ID=

# Backend API base URL. Leave empty for same-origin (dev uses Vite's proxy);
# set to a deployed backend for a hosted build. The casino-perps client reuses the
# existing server (PRD 0008 D5): https://perps-dex-aggregator.onrender.com
# NOTE: that origin must also be in the server's CORS_ALLOWED_ORIGINS and the
# Privy app's allowed origins, or login/onboarding/account calls are rejected.
VITE_API_BASE_URL=

# Hyperliquid venue (see docs/adr/0009-hyperliquid-venue-gateway-and-reconnect.md).
# REQUIRED to enable the Hyperliquid venue option in the app — there is no
# silent default. Allowed values: 'mainnet' | 'testnet'. Misconfigured or
# missing → the venue selector hides Hyperliquid.
VITE_HYPERLIQUID_NETWORK=
# Optional override for the Hyperliquid HTTP endpoint. Leave empty to use the
# canonical mainnet/testnet URL derived from VITE_HYPERLIQUID_NETWORK.
VITE_HYPERLIQUID_API_URL=

# Optional Arbitrum One RPC URL for the in-app deposit flow (USDC balance reads +
# transfer-receipt waits). Leave empty to use viem's default PUBLIC Arbitrum RPC,
# which is rate-limited — under load a balance read can fail and surface as
# "Something went wrong" on the deposit sheet. Set a dedicated endpoint
# (Alchemy / Infura / your node) for reliability, e.g.
# https://arb-mainnet.g.alchemy.com/v2/<key>. Invalid values are ignored with a
# warning and fall back to the default. NOTE: the URL may embed an API key — it is
# never logged (only custom-vs-default is). Baked in at build time (Vite).
VITE_ARBITRUM_RPC_URL=

# Deployed landing/marketing site base URL — the canonical home of the legal
# pages (ADR-0075). The order disclaimer's "Terms of Use" link deep-links to
# `${VITE_LANDING_URL}/terms`. Leave empty to fall back to the landing dev server
# (http://localhost:5173). Set it to the deployed landing domain in production.
# Baked in at build time (Vite).
VITE_LANDING_URL=

# Minara x402 recipient — the ONLY address the scoped signing delegation may pay
# (issue #205). REQUIRED to offer the delegation consent flow: a missing or
# malformed value hides the grant (the consent surface reports no scope). Must be
# a 20-byte EVM address; the server is the final allowlist authority and rejects
# any other recipient. Baked in at build time (Vite).
VITE_MINARA_X402_RECIPIENT=

# DEV-ONLY mock auth (see docs/adr/0055-dev-only-mock-auth-toggle.md). Set to
# 'true' to short-circuit Privy and report a connected mock wallet, so headless
# verification (Playwright / Spectate Mode) can render the Account Dock without
# an interactive login. ONLY active when the build is dev (`import.meta.env.DEV`);
# ignored in any production build. Optionally set VITE_MOCK_AUTH_ADDRESS to a
# 20-byte EVM address (a malformed value falls back to a placeholder). NEVER set
# either in a deployed build. Baked in at build time (Vite) — restart dev to apply.
# VITE_MOCK_AUTH=
# VITE_MOCK_AUTH_ADDRESS=

# Support inbox. The crash screen's "Email support" CTA and the rail's Live
# Support both point here. Leave empty to fall back to the brand inbox baked
# into app/support.config.ts. Baked in at build time (Vite).
# VITE_SUPPORT_EMAIL=

# Optional log-level override. Allowed values: 'debug' | 'info' | 'warn' | 'error'.
# When unset, defaults to 'debug' in dev and 'info' in production. A valid value
# wins in any mode — set it in your gitignored .env.local (e.g. VITE_LOG_LEVEL=warn)
# to quiet local debug noise. Invalid values are ignored with a warning, falling
# back to the default. Baked in at build time (Vite) — changing it requires a
# dev-server restart / rebuild. See apps/client/.claude/rules/logging.md.
# VITE_LOG_LEVEL=
